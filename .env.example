# Database connection string
# For local PostgreSQL: postgres://username:password@localhost:5432/artemist_development
# For Supabase: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://localhost:5432/artemist_development

# GitHub OAuth credentials (for user authentication)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Personal Access Token (for API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token
